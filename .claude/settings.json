{
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "github"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(node -e 'try{process.stdout.write(JSON.parse(require(\"fs\").readFileSync(0,\"utf8\")).tool_input.file_path||\"\")}catch{}'); case \"$f\" in *.md|*.markdown) npx --yes prettier --write \"$f\" >/dev/null 2>&1 || true;; esac",
            "timeout": 120,
            "statusMessage": "prettier (markdown)"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ponytail@ponytail": true,
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  }
}
